<Window x:Class="Hangman.View.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Hangman.View"
        Title="User Statistics" Height="500" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#FFE6EE">

    <Window.Resources>
        <local:RelativePathConverter x:Key="RelativePathConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
            <Border Width="110" Height="110" CornerRadius="55" 
                    BorderBrush="#FFB3C6" BorderThickness="3" Padding="3" Background="White">

                <Border CornerRadius="55">
                    <Border.OpacityMask>
                        <VisualBrush Stretch="Uniform">
                            <VisualBrush.Visual>
                                <Ellipse Fill="Black" Width="100" Height="100"/>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Border.OpacityMask>

                    <Image Source="{Binding CurrentUser.ProfileImagePath, Converter={StaticResource RelativePathConverter}}" 
                           Stretch="UniformToFill" 
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Width="100" Height="100"/>
                </Border>
            </Border>

            <TextBlock Text="{Binding CurrentUser.Name}" FontSize="24" FontWeight="Bold" Foreground="#B00050"
                       HorizontalAlignment="Center" Margin="0,10,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding CurrentUser.Statistics}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="15" Margin="0,0,0,10" Padding="15"
                                BorderBrush="#FFB3C6" BorderThickness="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding CategoryName}" FontSize="16" FontWeight="Bold" Foreground="#D6336C" VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center">
                                    <TextBlock Text="Played: " FontSize="14" FontWeight="Bold" Foreground="#FFB3C6"/>
                                    <TextBlock Text="{Binding GamesPlayed}" FontSize="14" FontWeight="Bold" Foreground="#D6336C"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Won: " FontSize="14" FontWeight="Bold" Foreground="#FFB3C6"/>
                                    <TextBlock Text="{Binding GamesWon}" FontSize="14" FontWeight="Bold" Foreground="Green"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button Grid.Row="2" Content="Close" Command="{Binding CloseCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" 
                Width="100" Height="35" Margin="0,15,0,0"
                Background="White" Foreground="#D6336C" FontWeight="Bold" FontSize="14"
                BorderBrush="#FFB3C6" BorderThickness="2" Cursor="Hand"/>
    </Grid>
</Window>