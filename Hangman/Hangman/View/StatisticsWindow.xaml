<Window x:Class="Hangman.View.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Hangman.View"
        Title="Statistics" Height="600" Width="450"
        WindowStartupLocation="CenterScreen"
        Background="#FFE6EE">

    <Window.Resources>
        <local:RelativePathConverter x:Key="RelativePathConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding AllUsers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="15" Margin="0,0,0,15" Padding="15"
                                BorderBrush="#FFB3C6" BorderThickness="2">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Width="50" Height="50" CornerRadius="25"
                                            BorderBrush="#FFB3C6" BorderThickness="2" Padding="2" Background="White">
                                        <Border CornerRadius="23">
                                            <Border.OpacityMask>
                                                <VisualBrush Stretch="Uniform">
                                                    <VisualBrush.Visual>
                                                        <Ellipse Fill="Black" Width="44" Height="44"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Border.OpacityMask>
                                            <Image Source="{Binding ProfileImagePath, Converter={StaticResource RelativePathConverter}}"
                                                   Stretch="UniformToFill" Width="44" Height="44"/>
                                        </Border>
                                    </Border>
                                    <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold"
                                               Foreground="#B00050" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding Statistics}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding CategoryName}"
                                                           FontSize="14" FontWeight="Bold" Foreground="#D6336C" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,15,0">
                                                    <TextBlock Text="Played: " FontSize="13" Foreground="#FFB3C6"/>
                                                    <TextBlock Text="{Binding GamesPlayed}" FontSize="13" FontWeight="Bold" Foreground="#D6336C"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                    <TextBlock Text="Won: " FontSize="13" Foreground="#FFB3C6"/>
                                                    <TextBlock Text="{Binding GamesWon}" FontSize="13" FontWeight="Bold" Foreground="Green"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button Grid.Row="1" Content="Close" Command="{Binding CloseCommand}"
                CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                Width="100" Height="35" Margin="0,15,0,0"
                Background="White" Foreground="#D6336C" FontWeight="Bold" FontSize="14"
                BorderBrush="#FFB3C6" BorderThickness="2" Cursor="Hand"/>
    </Grid>
</Window>