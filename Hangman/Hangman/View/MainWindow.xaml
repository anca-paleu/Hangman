<Window x:Class="Hangman.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Hangman.View"
        Title="Hangman - Sign In" Height="500" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#FFE6EE">
    <Window.Resources>
        <local:RelativePathConverter x:Key="RelativePathConverter"/>
        <Style TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#D6336C"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="10,0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#FFB3C6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFD1DC"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                    <Setter Property="Background" Value="#F2F2F2"/>
                    <Setter Property="BorderBrush" Value="#D9D9D9"/>
                    <Setter Property="Foreground" Value="#999999"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Welcome to Hangman!" 
                   FontSize="32" FontWeight="Black" Foreground="#B00050" 
                   HorizontalAlignment="Center" Margin="0,0,0,30"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="15" Padding="15">
                <ListBox ItemsSource="{Binding Users}" 
                         SelectedItem="{Binding SelectedUser, Mode=TwoWay}" 
                         DisplayMemberPath="Name"/>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="15" Padding="15">
                <Image Source="{Binding SelectedUser.ProfileImagePath, Converter={StaticResource RelativePathConverter}}" 
                       Stretch="Uniform" 
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Margin="5"/>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
            <Button Content="New User" Command="{Binding NewUserCommand}" Width="120"/>
            <Button Content="Delete User" Command="{Binding DeleteUserCommand}" Width="120"/>
            <Button Content="Play" Command="{Binding PlayCommand}" Width="120"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}" Width="120"/>
        </StackPanel>
    </Grid>
</Window>
