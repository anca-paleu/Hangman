<Window x:Class="Hangman.View.NewUser"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create New User" Height="350" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="#FFE6EE">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Username:" FontWeight="Bold" FontSize="14" Foreground="#D6336C"/>

        <TextBox Name="txtUsername" Grid.Row="1" Margin="0,5,0,10" Padding="5" FontSize="14"
                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">

            <Button Content="&lt;" Command="{Binding PrevCommand}" Width="40" Height="40"
                    Background="White" Foreground="#D6336C" FontWeight="Bold" FontSize="18"
                    BorderBrush="#FFB3C6" BorderThickness="2" Cursor="Hand"/>

            <Border Background="White" CornerRadius="10" Margin="15,0" Padding="5">
                <Image Name="imgAvatar" Width="100" Height="100" Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Source="{Binding CurrentAvatar}"/>
            </Border>

            <Button Content="&gt;" Command="{Binding NextCommand}" Width="40" Height="40"
                    Background="White" Foreground="#D6336C" FontWeight="Bold" FontSize="18"
                    BorderBrush="#FFB3C6" BorderThickness="2" Cursor="Hand"/>

        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Save" Command="{Binding SaveCommand}" Width="80" Margin="0,0,10,0"
                    Background="White" Foreground="Green" FontWeight="Bold" BorderBrush="LightGreen" BorderThickness="2"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}" Width="80"
                    Background="White" Foreground="Red" FontWeight="Bold" BorderBrush="LightPink" BorderThickness="2"/>
        </StackPanel>
    </Grid>
</Window>
