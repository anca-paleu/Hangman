<Window x:Class="Hangman.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Hangman.View"
        Title="Hangman - Sign In" Height="500" Width="750"
        WindowStartupLocation="CenterScreen"
        Background="#FFF0F5">

    <Window.Resources>
        <local:RelativePathConverter x:Key="RelativePathConverter"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#D6336C"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="10,0"/>
            <Setter Property="BorderBrush" Value="#FFB3C6"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,20">
            <TextBlock Text="HANGMAN" FontSize="40" FontWeight="Black" Foreground="#B00050" HorizontalAlignment="Center"/>
            <TextBlock Text="Who's playing today?" FontSize="18" Foreground="#D6336C" HorizontalAlignment="Center"/>
        </StackPanel>

        <ListBox Grid.Row="1" ItemsSource="{Binding Users}" 
                 SelectedItem="{Binding SelectedUser, Mode=TwoWay}" 
                 Background="Transparent" BorderThickness="0" 
                 HorizontalAlignment="Center" VerticalAlignment="Center">

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="15" Width="100">

                        <Ellipse Width="80" Height="80" Stroke="#FFB3C6" StrokeThickness="2">
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="{Binding ProfileImagePath, Converter={StaticResource RelativePathConverter}}" Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>

                        <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" Foreground="#B00050" 
                                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,10">
            <Button Content="New User" Command="{Binding NewUserCommand}" Width="120" Height="40"/>
            <Button Content="Delete User" Command="{Binding DeleteUserCommand}" Width="120" Height="40"/>

            <Button Content="Play" Command="{Binding PlayCommand}" Width="140" Height="40" 
                    Background="#D6336C" Foreground="White" BorderBrush="#B00050"/>

            <Button Content="Exit" Command="{Binding CancelCommand}" Width="120" Height="40"/>
        </StackPanel>
    </Grid>
</Window>