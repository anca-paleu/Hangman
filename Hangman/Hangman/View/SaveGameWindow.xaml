<Window x:Class="Hangman.View.SaveGameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Save Game" Height="250" Width="350"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#FFE6EE">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Enter a name for your game:" FontSize="16" FontWeight="Bold" Foreground="#D6336C" HorizontalAlignment="Center" Margin="0,0,0,15"/>
            <TextBox Text="{Binding SaveName, UpdateSourceTrigger=PropertyChanged}" FontSize="16" Padding="5" BorderBrush="#FFB3C6" BorderThickness="2"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25,0,0">
                <Button Content="Save" Command="{Binding SaveCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" 
                        Width="80" Height="35" Margin="0,0,15,0"
                        Background="White" Foreground="Green" FontWeight="Bold" FontSize="14" BorderBrush="LightGreen" BorderThickness="2" Cursor="Hand"/>
                <Button Content="Cancel" Command="{Binding CancelCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" 
                        Width="80" Height="35"
                        Background="White" Foreground="#D6336C" FontWeight="Bold" FontSize="14" BorderBrush="LightPink" BorderThickness="2" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>