<Window x:Class="Hangman.View.OpenGameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Load Game" Height="400" Width="350"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#FFE6EE">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Select a game:" FontSize="16" FontWeight="Bold" Foreground="#D6336C" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <ListBox Grid.Row="1" ItemsSource="{Binding SavedGames}" SelectedItem="{Binding SelectedGame}" 
                 Background="White" BorderBrush="#FFB3C6" BorderThickness="2" Padding="5">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,5">
                        <TextBlock Text="{Binding SaveName}" FontSize="16" FontWeight="Bold" Foreground="#B00050"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Category: " FontSize="12" Foreground="#D6336C"/>
                            <TextBlock Text="{Binding Category}" FontSize="12" FontWeight="Bold" Foreground="#D6336C"/>
                            <TextBlock Text=" | Level: " FontSize="12" Foreground="#D6336C"/>
                            <TextBlock Text="{Binding Level}" FontSize="12" FontWeight="Bold" Foreground="#D6336C"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="Play" Command="{Binding OpenCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" 
                    Width="100" Height="35" Margin="0,0,15,0"
                    Background="White" Foreground="Green" FontWeight="Bold" FontSize="14" BorderBrush="LightGreen" BorderThickness="2" Cursor="Hand"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" 
                    Width="100" Height="35"
                    Background="White" Foreground="#D6336C" FontWeight="Bold" FontSize="14" BorderBrush="LightPink" BorderThickness="2" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>